#!/bin/sh
# pre-push hook: reject pushes containing any commit whose message credits an
# AI tool or adds co-authoring text. Backstop for the commit-msg hook (catches
# commits made with --no-verify, amended, or authored by other tools).
#
# Wired via core.hooksPath .githooks (see web/package.json "prepare"). Paths are
# repo-root-relative because core.hooksPath resolves against the worktree root.

. ci/attribution-check.sh

# True when an OID is all zeros (a deleted/absent ref). Length-agnostic so it
# works for both sha1 and sha256 repositories.
is_zero() {
    case "$1" in
        *[!0]*) return 1 ;;
        *) return 0 ;;
    esac
}

status=0

# git feeds the hook lines of: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r local_ref local_sha remote_ref remote_sha; do
    # Branch deletion: nothing to scan.
    is_zero "$local_sha" && continue

    if is_zero "$remote_sha"; then
        # New branch on the remote: scan commits not already on any remote ref.
        range=$(git rev-list "$local_sha" --not --remotes)
    else
        range=$(git rev-list "$remote_sha..$local_sha")
    fi

    for sha in $range; do
        if ! git log -1 --format=%B "$sha" | ai_attribution_scan "commit $sha"; then
            status=1
        fi
    done
done

exit $status
